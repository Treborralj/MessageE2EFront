<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="is.hi.messagee2efront.ui.controller.InboxController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label fx:id="titleLabel" text="Incoming messages"/>

    <HBox spacing="10">
        <Button fx:id="refreshButton" text="Refresh" onAction="#onRefreshClick"/>
        <Button text="Open conversation" onAction="#onOpenConversationClick"/>
        <Button text="Logout" onAction="#onLogoutClick"/>
    </HBox>

    <ListView fx:id="inboxListView" prefHeight="400.0"/>

    <Label fx:id="statusLabel"/>
</VBox>